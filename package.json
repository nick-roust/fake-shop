{
  "name": "fake-shop",
  "version": "0.0.0",
  "private": true,
  "description": "Independent open-source reference commerce application for local demos and checkout integration experiments.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check",
    "demo:check": "node scripts/demo-foundation-check.mjs",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "test": "pnpm run test:typecheck && node scripts/run-tests.mjs",
    "test:typecheck": "tsc --noEmit --project tsconfig.test.json",
    "test:unit": "node scripts/run-tests.mjs unit",
    "test:integration": "node scripts/run-tests.mjs integration",
    "test:e2e": "node scripts/run-tests.mjs e2e",
    "test:smoke": "node scripts/run-tests.mjs smoke"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.31.0",
    "eslint-config-next": "^16.2.10",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "overrides": {
    "postcss": "8.5.16"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
