{
  "name": "fake-shop",
  "version": "0.0.0",
  "private": true,
  "description": "Independent open-source reference commerce application for local demos and checkout integration experiments.",
  "license": "MIT",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "node scripts/bootstrap-status.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3"
  }
}
