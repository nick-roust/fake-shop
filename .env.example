# fake-shop defaults to mock mode during local development.
FAKE_SHOP_MODE=mock

# Optional public app URL for future local development.
FAKE_SHOP_PUBLIC_URL=http://localhost:3000

# Optional base URL used by route smoke checks.
FAKE_SHOP_SMOKE_BASE_URL=http://127.0.0.1:3000

# Optional external API mode settings. Leave unset for mock mode.
# FAKE_SHOP_EXTERNAL_API_URL=
